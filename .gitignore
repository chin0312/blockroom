# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/artifacts/
/cache/
/ignition/deployments/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# Hackathon demo production files stay local and never enter the product repo.
demo-assets/
scripts/demo-record.mjs
scripts/render-screencast.swift

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

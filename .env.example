# Required for real different-browser rooms. Use the public values from
# Supabase Project Settings > API. No service-role or private key belongs here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Compatibility only for older Supabase projects. Prefer the publishable key.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required for Reown AppKit wallet selection and WalletConnect QR sessions.
# Create a public project ID at https://dashboard.reown.com.
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Must match an origin allowed in the Reown project settings.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional public RPC overrides. When omitted, BlockRoom uses each chain's
# documented public testnet RPC from the central chain registry.
NEXT_PUBLIC_MONAD_TESTNET_RPC_URL=
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=
NEXT_PUBLIC_ETHEREUM_SEPOLIA_RPC_URL=

# Public contract addresses. Populate only after a real deployment succeeds.
NEXT_PUBLIC_MONAD_TESTNET_SESSION_CONTRACT=
NEXT_PUBLIC_MONAD_TESTNET_BADGE_CONTRACT=
NEXT_PUBLIC_BASE_SEPOLIA_SESSION_CONTRACT=
NEXT_PUBLIC_BASE_SEPOLIA_BADGE_CONTRACT=
NEXT_PUBLIC_ETHEREUM_SEPOLIA_SESSION_CONTRACT=
NEXT_PUBLIC_ETHEREUM_SEPOLIA_BADGE_CONTRACT=

# Contract deployment only. Never prefix private deployment values with
# NEXT_PUBLIC_, never expose them to Vercel, and never commit a populated value.
MONAD_TESTNET_RPC_URL=
BASE_SEPOLIA_RPC_URL=
ETHEREUM_SEPOLIA_RPC_URL=
BLOCKROOM_DEPLOYER_PRIVATE_KEY=
ETHERSCAN_API_KEY=

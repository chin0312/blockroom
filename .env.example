# Required for real different-browser rooms. Use the public values from
# Supabase Project Settings > API. No service-role or private key belongs here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Compatibility only for older Supabase projects. Prefer the publishable key.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required for Reown AppKit wallet selection and WalletConnect QR sessions.
# Create a public project ID at https://dashboard.reown.com.
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Must match an origin allowed in the Reown project settings.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public address of the deployed BlockRoom contract on Monad Testnet.
# Leave empty until a real deployment succeeds; never use a fabricated address.
NEXT_PUBLIC_BLOCKROOM_CONTRACT_ADDRESS=
NEXT_PUBLIC_BLOCKROOM_DEPLOYMENT_TX=

# Contract deployment only. Never prefix private deployment values with
# NEXT_PUBLIC_, never expose them to Vercel, and never commit a populated value.
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_DEPLOYER_PRIVATE_KEY=
MONADSCAN_API_KEY=
